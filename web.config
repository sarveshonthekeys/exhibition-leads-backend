<configuration>
  <system.webServer>    
    <rewrite>
      <rules>
                <rule name="ApiReverseProxy" stopProcessing="true">
                    <match url="(.*)" />
                    <action type="Rewrite" url="http://localhost:3003/{R:1}" />
                </rule>
      </rules>
    </rewrite>

    <iisnode node_env="production" nodeProcessCommandLine="&quot;C:\Program Files\nodejs\node.exe&quot;" interceptor="&quot;%programfiles%\iisnode\interceptor.js&quot;" />

  </system.webServer>
    <location path="" overrideMode="Deny">
        <system.webServer>
    <handlers>
      <add name="iisnode" path="dist/src/main.js" verb="*" modules="iisnode" />
    </handlers>
        </system.webServer>
    </location>
</configuration>