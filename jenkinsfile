pipeline {
    agent any

    environment {
        WORKSPACE_PATH = "C:/Users/copiacsvmadmin/AppData/Local/Jenkins/.jenkins/workspace/Exhibition_APP_API"
        DEPLOY_PATH = "C:/inetpub/Sites/EXHIBITION_APP_API"
        NODE_ENV = "production"
    }

    options {
        timeout(time: 60, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'develop',
                    credentialsId: 'c9cfb0ee-1b54-4239-a00b-4e21c9556dc7',
                    url: 'https://github.com/CopiaGithub/ExhibitionApp_API.git'
            }
        }

        stage('Verify Node') {
            steps {
                bat 'node -v'
                bat 'npm -v'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Build Application') {
            steps {
                bat 'npm run build'
            }
        }

        stage('Stop PM2') {
            steps {
                script {
                    echo 'Stopping PM2'
                    bat """
                    cd /d "${DEPLOY_PATH}"
                    npm run pm2-stop
                    """
                }
            }
        }

        stage('Deploy Files') {
            steps {
                script {

                    bat """
                    if not exist "${DEPLOY_PATH}" mkdir "${DEPLOY_PATH}"
                    """

                    bat """
                    robocopy "${WORKSPACE_PATH}" "${DEPLOY_PATH}" /E /R:2 /W:2 /XD .git node_modules
                    if %ERRORLEVEL% LEQ 7 exit /B 0
                    exit /B %ERRORLEVEL%
                    """
                }
            }
        }

        stage('Prisma Generate') {
            steps {
                bat """
                cd /d "${DEPLOY_PATH}"
                npx prisma generate
                """
            }
        }

        stage('Start PM2') {
            steps {
                bat """
                cd /d "${DEPLOY_PATH}"
                npm run pm2-start
                """
            }
        }
    }

    post {
        success {
            echo 'Deployment completed successfully'
        }

        failure {
            echo 'Deployment failed'
        }
    }
}